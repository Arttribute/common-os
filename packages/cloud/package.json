{
	"name": "@common-os/cloud",
	"version": "0.2.0",
	"description": "Cloud provider abstraction for CommonOS — AWS EC2 and GCP Compute Engine",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "jest --passWithNoTests"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=22"
	},
	"dependencies": {
		"@aws-sdk/client-ec2": "^3.808.0",
		"@google-cloud/compute": "^4.9.0"
	},
	"devDependencies": {
		"@types/jest": "^29.5.14",
		"jest": "^29.7.0",
		"ts-jest": "^29.2.5",
		"tsup": "^8.5.1",
		"typescript": "^5.7.3"
	}
}
