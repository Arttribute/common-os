{
  "name": "common-os",
  "version": "1.0.0",
  "private": true,
  "description": "Deployment and management framework for persistent AI agent fleets",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "pnpm --filter './packages/*' run test --passWithNoTests",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "version-ci": "changeset version && git checkout -- apps/web/package.json",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "husky": "^9.1.7",
    "turbo": "^2.9.6",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
