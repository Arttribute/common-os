# API: MongoDB
MONGODB_URI=mongodb+srv://...
PORT=3001
API_URL=http://localhost:3001

# Web app
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_API_KEY=

# Web -> docs multi-zone rewrite
# Local: http://localhost:3002
# Production: https://<your-docs-vercel-project>.vercel.app
DOCS_ORIGIN=http://localhost:3002

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
EKS_CLUSTER=common-os-agents

# GCP
GCP_PROJECT_ID=
GCP_SERVICE_ACCOUNT_KEY=
GCP_REGION=europe-west1
GKE_CLUSTER=common-os-agents
AGENT_IMAGE_URL=
RUNNER_URL=
CLOUD_PROVIDER=gcp
AXL_MODE=explicit

# Agent Commons
AGC_API_URL=
AGENTCOMMONS_API_KEY=
AGC_INITIATOR=

# OpenClaw
# Set OPENCLAW_IMAGE_URL to launch a Gateway sidecar per OpenClaw agent.
# Or set OPENCLAW_GATEWAY_URL to route all OpenClaw agents to an existing Gateway.
OPENCLAW_IMAGE_URL=
OPENCLAW_GATEWAY_URL=
OPENCLAW_MODEL_PROVIDER=openai
OPENCLAW_MODEL_ID=openai/gpt-4o-mini
OPENCLAW_MODEL_API_KEY=

# Auth
PRIVY_APP_ID=
PRIVY_APP_SECRET=
